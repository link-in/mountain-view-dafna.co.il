# Cardcom / קארדקום — Payment Gateway
# הוסף את המשתנים האלה ל-.env.local ולדשבורד של Vercel

# כתובת API של קארדקום (ברירת מחדל — אין צורך לשנות)
CARDCOM_API_URL=https://secure.cardcom.solutions/api/v11

# מספר הטרמינל שלך (5-6 ספרות) — תמצא בלוח הניהול:
# הגדרות → הגדרות חברה → ניהול API Keys
CARDCOM_TERMINAL_NUMBER=your_terminal_number

# מפתח ה-API שקיבלת מקארדקום (UUID)
CARDCOM_API_NAME=your-cardcom-api-uuid

# סיסמת API — נדרשת רק להחזרים (Refund). ניתן להשאיר ריק כעת.
CARDCOM_API_PASSWORD=

# סוג פעולת ברירת מחדל: ChargeOnly | CreateTokenOnly | ChargeAndCreateToken
CARDCOM_OPERATION=ChargeOnly

# כתובת האתר (לקישורי חזרה מקארדקום)
NEXT_PUBLIC_SITE_URL=https://mountain-view-dafna.co.il

# ─── מצב בדיקות מבוסס URL — בטוח לפרודקשן ─────────────────────────────────
# הוסף לכתובת ?test=<הטוקן> כדי לבצע תשלום-דמה ללא חיוב אמיתי.
# בלי הפרמטר → תשלום אמיתי דרך Cardcom.
# החלף לערך אקראי סודי. אל תשתף.
CARDCOM_TEST_TOKEN=replace-with-a-long-random-secret

# ─── מצב פיתוח לוקאלי בלבד ─────────────────────────────────────────────────
# אם true — תמיד mock, ללא צורך ב-?test=. בפרודקשן השאר false.
CARDCOM_MOCK_MODE=false

# Invoice4U — חשבונית מס קבלה אחרי תשלום מוצלח
INVOICE4U_API_KEY=your-invoice4u-api-key
INVOICE4U_CREATE_URL=https://api.invoice4u.co.il/Services/ApiService.svc/CreateDocument
# אימייל של בעל העסק — יקבל עותק של כל חשבונית (IsUserMail: true)
INVOICE4U_OWNER_EMAIL=your-email@example.com
